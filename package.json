{
  "name": "@staffforge/staffforge-ai-agent-framework",
  "publishConfig": {
    "access": "public"
  },
  "version": "2.6.0",
  "license": "GPL-3.0-only",
  "description": "Multi-provider AI agent framework. Write agents once, deploy anywhere.",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/dev-link.mjs",
    "setup": "node install.mjs",
    "setup:opencode": "node install.mjs --platform opencode --agent orchestrator -y",
    "setup:build": "node install.mjs --platform opencode --agent orchestrator -y",
    "setup:plan": "node install.mjs --platform opencode --agent orchestrator -y",
    "export": "node tools/export.mjs --all",
    "export:opencode": "node tools/export.mjs --platform opencode",
    "export:claude": "node tools/export.mjs --platform claude-code",
    "export:cursor": "node tools/export.mjs --platform cursor",
    "export:copilot": "node tools/export.mjs --platform copilot",
    "export:aider": "node tools/export.mjs --platform aider",
    "export:gemini": "node tools/export.mjs --platform gemini-cli",
    "validate": "node tools/validate.mjs",
    "test": "node tests/run-all.mjs",
    "lint": "eslint 'tools/**/*.mjs' 'packages/**/*.mjs'",
    "format": "prettier --check 'tools/**/*.mjs' 'packages/**/*.mjs'",
    "format:fix": "prettier --write 'tools/**/*.mjs' 'packages/**/*.mjs'",
    "init-agent": "node tools/init-agent.mjs",
    "init-skill": "node tools/init-skill.mjs",
    "docs": "node tools/generate-docs.mjs",
    "publish:cli": "cd packages/cli && npm publish",
    "publish:core": "cd packages/core && npm publish",
    "publish:sdk": "cd packages/sdk && npm publish",
    "publish:plugin-sdk": "cd packages/plugin-sdk && npm publish"
  },
  "bin": {
    "staffforge": "./packages/cli/install.mjs"
  },
  "files": [
    "install.mjs",
    "packages/",
    "agents/",
    "skills/",
    "schemas/",
    "templates/",
    "adapters/",
    "tools/",
    "scripts/",
    "README.md",
    "AGENTS.md",
    "ORCHESTRATOR_MATRIX.md"
  ],
  "exports": {
    "./skill-loader": "./tools/skill-loader.mjs"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "js-yaml": "^4.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StaffForge/StaffForge-AI-Agent-Framework.git"
  },
  "homepage": "https://github.com/StaffForge/StaffForge-AI-Agent-Framework#readme"
}